{
	"$schema": "https://raw.githubusercontent.com/infinum/eightshift-frontend-libs/develop/schemas/component.json",
	"componentName": "button",
	"title": "Button",
	"attributes": {
		"buttonUrl": {
			"type": "string"
		},
		"buttonLabel": {
			"type": "string"
		},
		"buttonAttrs": {
			"type": "object"
		},
		"buttonIcon": {
			"type": "string"
		},
		"buttonIconSize": {
			"type": "string"
		},
		"buttonIsDisabled": {
			"type": "boolean"
		},
		"buttonNewTab": {
			"type": "boolean",
			"default": false
		}
	}
}
