{
	"$schema": "https://raw.githubusercontent.com/infinum/eightshift-frontend-libs/develop/schemas/component.json",
	"componentName": "card-listing",
	"title": "Card Listing",
	"componentClass": "es-card-listing",
	"attributes": {
		"cardListingTitle": {
			"type": "string"
		},
		"cardListingUrl": {
			"type": "string"
		},
		"cardListingSubTitle": {
			"type": "string"
		},
		"cardListingContent": {
			"type": "string"
		},
		"cardListingIcon": {
			"type": "string"
		},
		"cardListingRightContent": {
			"type": "string"
		},
		"cardListingUseCheckbox": {
			"type": "boolean",
			"default": false
		},
		"cardListingId": {
			"type": "string"
		},
		"cardListingInvalid": {
			"type": "boolean",
			"default": false
		}
	}
}
